using BancsEventsLogger.Models;
using System;
using System.Collections.Generic;
using System.Configuration;
using System.Diagnostics.Eventing.Reader;
using System.Web.Mvc;

namespace BancsEventsLogger.Controllers
{
    public class LogController : Controller
    {
        public ActionResult Index(string findText)
        {
            var logs = new List<LogEntry>();
            string channelName = ConfigurationManager.AppSettings["EventLogChannel"];
            int defaultLimit = 500;

            try
            {
                var query = new EventLogQuery(channelName, PathType.LogName);
                using (var reader = new EventLogReader(query))
                {
                    EventRecord record;
                    while ((record = reader.ReadEvent()) != null)
                    {
                        using (record)
                        {
                            string msg = record.FormatDescription() ?? "";
                            bool isMatch = string.IsNullOrEmpty(findText) ||
                                           msg.IndexOf(findText, StringComparison.OrdinalIgnoreCase) >= 0;

                            if (isMatch)
                            {
                                logs.Add(new LogEntry
                                {
                                    Level = record.LevelDisplayName,
                                    TimeCreated = record.TimeCreated,
                                    Source = record.ProviderName,
                                    EventId = record.Id,
                                    Message = msg,
                                    TellerId = ExtractTeller(msg)
                                });
                            }

                            if (string.IsNullOrEmpty(findText) && logs.Count >= defaultLimit) break;
                        }
                    }
                }
                logs.Reverse();
            }
            catch (Exception ex) { ViewBag.Error = "Log Access Error: " + ex.Message; }
            return View(logs);
        }

        private string ExtractTeller(string msg)
        {
            if (msg.StartsWith("Teller("))
            {
                int start = msg.IndexOf('(') + 1;
                int end = msg.IndexOf(" -");
                if (start > 0 && end > start) return msg.Substring(start, end - start);
            }
            return "Not Available";
        }
    }
}
