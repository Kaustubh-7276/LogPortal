@model IEnumerable<BancsEventsLogger.Models.LogEntry>
@{ ViewBag.Title = "DEV Region TX/RX Logs"; }

@section Styles {
    <link rel="stylesheet" href="~/Content/PortalCommon.css" />
}

<div class="container-fluid p-0 d-flex flex-column h-100">
    <div class="portal-card">
        <div class="row mb-3 align-items-center">
            <div class="col-md-5">
                <h4 class="m-0" style="color: var(--yono-blue); font-weight: 700;">DEVELOPMENT REGION LIVE TX/RX LOGS</h4>
                <small class="text-muted">@(string.IsNullOrEmpty(Request.QueryString["findText"]) ? "Last 500 entries loaded" : "Full scan results")</small>
            </div>
            <div class="col-md-7 text-end">
                <form method="get" class="d-inline-flex me-2">
                    <input type="text" name="findText" id="localSearch" class="form-control rounded-pill me-1" placeholder="Search..." value="@Request.QueryString["findText"]" style="width:180px;">
                    <button type="submit" class="btn btn-yono shadow-sm">Find</button>
                    <button type="button" onclick="location.href='@Url.Action("Index", "Log")'" class="btn btn-light border rounded-pill ms-1">Clear</button>
                </form>
                <button onclick="exportToCSV()" class="btn btn-export shadow-sm">📥 CSV</button>
                <span id="liveStatus" class="badge rounded-pill live-status px-3 py-2">🟢 LIVE</span>
                <span id="refreshTime" class="badge rounded-pill refresh-status px-3 py-2 ms-2">Refresh in 10s</span>
                <span id="lastRefresh" class="badge rounded-pill bg-info text-dark px-3 py-2 ms-2">Last Updated : --</span>
                <div class="form-check form-switch d-inline-block ms-2">
                    <input class="form-check-input" type="checkbox" id="autoRefresh" checked>
                    <label class="form-check-label" for="autoRefresh">Auto</label>
                </div>
                <button type="button" class="btn btn-light border rounded-pill ms-2" onclick="location.reload()">🔄 Refresh</button>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {<div class="alert alert-danger">@ViewBag.Error</div>}
        <div class="table-scroll">
            <table class="table table-hover mb-0" id="logTable">
                <thead>
                    <tr>
                        <th style="width:10%;">Teller ID</th>
                        <th style="width: 10%;">Level</th>
                        <th style="width: 160px;">Tran No</th>
                        <th>Message Detail</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td><span class="teller-badge">@log.TellerId</span></td>
                            <td><span class="fw-bold">@log.Level</span></td>
                            <td ><span class="teller-badge">@log.TranNo</span></td>
                            <td>
                                <button onclick="copyText('msg-@log.GetHashCode()')" class="btn-copy">📋 Copy</button>
                                <div id="msg-@log.GetHashCode()" class="msg-display">@log.Message</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
<div style="display:none;" class="copy-toast" id="copyToast">
    <span style="font-size:20px;">
        &#x2713;
    </span>
    <div>
        <strong>
            Copied Successfully
        </strong>
        <small>
            Message copied to clipboard.
        </small>
    </div>
</div>
<div style="display: none;" id="pageConfig" data-controller="Log" data-view="Index"></div>
@section scripts {
    <script src="~/Scripts/PortalCommon.js"></script>
}
