    Public Function CheckForDenialOfServiceSafe(ByVal content As String) As StringBuilder
        Dim ServiceStartVal As Integer = 0
        Dim ServiceEndVal As Integer = 0
        Dim ServiceString As New StringBuilder()
        For Each ch As Char In content
            If ch = "{"c Then
                ServiceStartVal += 1
            ElseIf ch = "}"c Then
                ServiceEndVal += 1
            End If
            ServiceString.Append(ch)
        Next
        If ServiceStartVal <> ServiceEndVal Then
            Throw New Exception("Malformed JSON: Mismatched braces.")
        End If

        Return ServiceString
    End Function
