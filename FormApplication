			}
			base.Close();
		}

		private void ButtonConnectClick(object sender, EventArgs e)
		{
			if (this.textBoxIP.get_Text() == "" || this.textBoxPort.get_Text() == "")
			{
				MessageBox.Show("IP Address and Port Number are required to connect to the Server\n");
			}
			else
			{
				try
				{
					this.UpdateControls(false);
					this.m_clientSocket = new Socket(2, 1, 6);
					IPAddress iPAddress = IPAddress.Parse(this.textBoxIP.get_Text());
					int num = (int)Convert.ToInt16(this.textBoxPort.get_Text());
					IPEndPoint iPEndPoint = new IPEndPoint(iPAddress, num);
					this.m_clientSocket.Connect(iPEndPoint);
					if (this.m_clientSocket.get_Connected())
					{
						this.UpdateControls(true);
						this.WaitForData();
					}
				}
				catch (SocketException ex)
				{
					string text = "\nConnection failed, is the server running?\n" + ex.get_Message();
					MessageBox.Show(text);
					this.UpdateControls(false);
				}
			}
		}

		private void ButtonSendMessageClick(object sender, EventArgs e)
		{
			try
			{
				string text = this.richTextTxMessage.get_Text();
				NetworkStream networkStream = new NetworkStream(this.m_clientSocket);
				StreamWriter streamWriter = new StreamWriter(networkStream);
				streamWriter.WriteLine(text);
				this.TimeValue.set_Text(string.Concat(new string[]
				{
					DateTime.get_Now().get_Hour().ToString(),
					" : ",
					DateTime.get_Now().get_Minute().ToString(),
					" : ",
					DateTime.get_Now().get_Second().ToString(),
					" : ",
					DateTime.get_Now().get_Millisecond().ToString()
				}));
				streamWriter.Flush();
			}
			catch (SocketException ex)
			{
				MessageBox.Show(ex.get_Message());
			}
		}

		public void WaitForData()
		{
			try
			{
				if (this.m_pfnCallBack == null)
				{
					this.m_pfnCallBack = new AsyncCallback(this.OnDataReceived);
				}
				SocketClient.SocketPacket socketPacket = new SocketClient.SocketPacket();
				socketPacket.thisSocket = this.m_clientSocket;
				this.m_result = this.m_clientSocket.BeginReceive(socketPacket.dataBuffer, 0, socketPacket.dataBuffer.Length, 0, this.m_pfnCallBack, socketPacket);
			}
			catch (SocketException ex)
			{
				MessageBox.Show(ex.get_Message());
			}
		}

		public void OnDataReceived(IAsyncResult asyn)
		{
			try
			{
				SocketClient.SocketPacket socketPacket = (SocketClient.SocketPacket)asyn.get_AsyncState();
				int num = socketPacket.thisSocket.EndReceive(asyn);
				char[] array = new char[checked((uint)(unchecked(num + 1)))];
				Decoder decoder = Encoding.get_UTF8().GetDecoder();
				int chars = decoder.GetChars(socketPacket.dataBuffer, 0, num, array, 0);
				string text = new string(array);
				this.richTextRxMessage.set_Text(this.richTextRxMessage.get_Text() + text);
				this.WaitForData();
			}
			catch (ObjectDisposedException)
			{
				Debugger.Log(0, "1", "\nOnDataReceived: Socket has been closed\n");
			}
			catch (SocketException ex)
			{
				MessageBox.Show(ex.get_Message());
			}
		}

		private void UpdateControls(bool connected)
		{
			this.buttonConnect.set_Enabled(!connected);
			this.buttonDisconnect.set_Enabled(connected);
			string text = connected ? "Connected" : "Not Connected";
			this.textBoxConnectStatus.set_Text(text);
		}

