    Public Function CheckForDenialOfService(ByVal ResponseReader As StreamReader) As Text.StringBuilder
        Dim str As New Text.StringBuilder()
        Dim ch As Char
        Do
            ch = Convert.ToChar(ResponseReader.Read())
            str.Append(ch.ToString)
        Loop While (ResponseReader.Peek() <> -1)
        Return str
    End Function
