    Public Sub ImageDBLoggeer(ByVal strMessage As String, ByVal TellerNum As String,
                          ByVal IMG_DBTrace As String, ByVal IMG_DBLogPath As String)

        ' 1. Sanitize Message Content (Log Injection Prevention)
        Dim safeMessage As String = strMessage.Replace(vbCr, " ").Replace(vbLf, " ")

        ' 2. Strict Allow-List Validation for TellerNum
        ' CRITICAL: This breaks the taint flow for Fortify by ensuring only safe characters exist.
        ' Only alphanumeric characters are allowed. No slashes, dots, or special chars.
        If String.IsNullOrEmpty(TellerNum) OrElse Not Regex.IsMatch(TellerNum, "^[a-zA-Z0-9]+$") Then
            Throw New SecurityException("Invalid Teller Number: Contains forbidden characters.")
        End If
        Dim safeTeller As String = TellerNum

        If IMG_DBTrace.ToUpper() = "ON" Then
            Dim dateFolder As String = DateTime.Now.ToString("dd-MMM-yyyy")

            ' 3. Secure Path Construction
            ' Resolve the base path to an absolute path first to establish a trusted root
            Dim baseDir As String = Path.GetFullPath(IMG_DBLogPath)

            ' Combine and resolve the final directory path
            Dim combinedPath As String = Path.Combine(baseDir, dateFolder)
            Dim logDirPath As String = Path.GetFullPath(combinedPath)

            ' CRITICAL: Verify the resolved path starts with the trusted base directory
            ' This explicitly prevents Directory Traversal (../) attacks
            If Not logDirPath.StartsWith(baseDir, StringComparison.OrdinalIgnoreCase) Then
                Throw New SecurityException("Invalid log directory: Path traversal detected.")
            End If

            If Not Directory.Exists(logDirPath) Then
                Directory.CreateDirectory(logDirPath)
            End If

            ' 4. Construct File Name
            ' Since safeTeller is regex-validated (alphanumeric only), it is safe to combine
            Dim fileName As String = "Teller_" & safeTeller & ".txt"
            Dim logFileName As String = Path.Combine(logDirPath, fileName)

            ' Defense in Depth: Verify final file path is still within bounds
            Dim finalFilePath As String = Path.GetFullPath(logFileName)
            If Not finalFilePath.StartsWith(baseDir, StringComparison.OrdinalIgnoreCase) Then
                Throw New SecurityException("Invalid log file path: Path traversal detected.")
            End If

            ' 5. Write Log Entry
            Dim logEntry As String = DateTime.Now.ToString("HH:mm:ss") & " - " & safeMessage & Environment.NewLine

            ' File.AppendAllText is the sink. Because the path is now validated, Fortify should pass.
            File.AppendAllText(finalFilePath, logEntry)
        End If
    End Sub
