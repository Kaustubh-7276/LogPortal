    Public Function OpenXmlDoc(ByVal filePath As String) As XmlDocument
        Dim validate As Owasp.Esapi.Encoder = New Owasp.Esapi.Encoder()
        filePath = validate.Canonicalize(Path.GetFullPath(filePath))
        Try
            Dim goodSettingsws As New XmlReaderSettings With {
                .DtdProcessing = DtdProcessing.Ignore,
                .XmlResolver = Nothing,
                .ValidationType = ValidationType.Schema,
                .Schemas = New System.Xml.Schema.XmlSchemaSet(),
                .MaxCharactersFromEntities = 1024,
                .IgnoreComments = True
            }
            Using goodxmlreadws As XmlReader = XmlReader.Create(filePath, goodSettingsws)
                Dim xmlDoc As New System.Xml.XmlDocument()
                xmlDoc.Load(goodxmlreadws)
                goodxmlreadws.Close()
                Return xmlDoc
            End Using
        Catch ex As System.IO.FileNotFoundException
            Throw New System.IO.FileNotFoundException
            Return Nothing
        Catch ex As System.IO.IOException
            Throw New System.IO.IOException
            Return Nothing
        Catch ex As System.Xml.XmlException
            Throw New System.Xml.XmlException
            Return Nothing
        Catch ex As System.Security.SecurityException
            Throw New System.Security.SecurityException
            Return Nothing
        Catch ex As Exception
            Throw New Exception(ex.Message)
            Return Nothing
        End Try
    End Function

    Public Function SanitizeInput(ByVal input As String) As String
        Dim validate As Owasp.Esapi.Encoder = New Owasp.Esapi.Encoder()
        If Not String.IsNullOrEmpty(validate.Canonicalize(input)) Then
            Return System.Security.SecurityElement.Escape(input)
        Else
            Return String.Empty
        End If
    End Function

    Private Function GetSafeInnerText(ByVal node As XmlNode) As String
        If node Is Nothing Then Return String.Empty
        Return node.InnerText
    End Function

